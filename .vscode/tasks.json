{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cargo",
            "command": "run",
            "args": ["--", "${fileDirnameBasename}", "${fileBasenameNoExtension}"],
            "problemMatcher": ["$rustc"],
            "label": "Run: Current Year/Puzzle",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cargo",
            "command": "run",
            "args": ["--release", "--", "${fileDirnameBasename}", "${fileBasenameNoExtension}"],
            "problemMatcher": ["$rustc"],
            "label": "Run: Current Year/Puzzle (Release)",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cargo",
            "command": "run",
            "args": [],
            "problemMatcher": ["$rustc"],
            "label": "Run: All Solutions",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cargo",
            "command": "run",
            "args": ["--release"],
            "problemMatcher": ["$rustc"],
            "label": "Run: All Solutions (Release)",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "cargo",
            "command": "build",
            "problemMatcher": ["$rustc"],
            "label": "Build: Debug",
            "group": "build"
        },
        {
            "type": "cargo",
            "command": "build",
            "args": ["--release"],
            "problemMatcher": ["$rustc"],
            "label": "Build: Release",
            "group": "build"
        },
        {
            "type": "cargo",
            "command": "test",
            "problemMatcher": ["$rustc"],
            "label": "Test: All",
            "group": "test"
        }
    ],
}
